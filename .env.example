FEATHERLESS_API_KEY=your_featherless_api_key_here

# Per-agent Featherless keys (optional — fall back to FEATHERLESS_API_KEY if unset)
# System Diagnostics Agent does NOT use Featherless — only Band URLs below + diagnostics/agent_config.yaml
FEATHERLESS_API_KEY_ORCHESTRATOR=
FEATHERLESS_API_KEY_DEFENDER=
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Model configurations (optional — fall back to Qwen/Qwen3-32B if unset)
# FEATHERLESS_MODEL is the global model fallback (e.g. Qwen/Qwen3-0.6B for speed, Qwen/Qwen3-32B for quality)
FEATHERLESS_MODEL=
FEATHERLESS_MODEL_ORCHESTRATOR=
FEATHERLESS_MODEL_TRIAGE=
FEATHERLESS_MODEL_PROSECUTOR=
FEATHERLESS_MODEL_DEFENDER=
FEATHERLESS_MODEL_JUDGE=

